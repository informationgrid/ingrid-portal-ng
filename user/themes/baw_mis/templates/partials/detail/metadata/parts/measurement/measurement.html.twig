{# Messdaten #}

<div class="section">
    <a class="anchor" id="{{ hash_measurement }}"></a>
    {{ hit_macros.render_title("SEARCH_DETAIL.MEASUREMENT.TITLE"|t) }}
    <div class="sub-section">
    {# Raumbezugssystem (Höhe) #}

    {# Vertikale Ausdehnung (Min/Max) #}

    {# Bwstr Bezug (Name / Kennung) #}

    {# Messverfahren #}
