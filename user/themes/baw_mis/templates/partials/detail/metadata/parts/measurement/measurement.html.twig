    {# Messgerät (Name/ID/Modell) #}
        {% set header = [
            "Gerätename",
            "Geräte-ID",
            "Gerätemodell",
            "Beschreibung"
        ] %}
        {{ hit_macros.render_table("Messgerät", header, measurement.gauge) }}
