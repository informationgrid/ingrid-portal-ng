        {% set header = [
            "Name",
            "Art",
            "Einheit",
            "Formel/Funktion"
        ] %}
        {{ hit_macros.render_table("Zielparameter", header, measurement.targetParameters) }}
    {# Räumlichkeit #}

    {# Messtiefe #}

    {# Frequenz der Messung #}

    {# Gemittelter Wasserstand #}

    {# Pegelnullpunkt #}

    {# Abfluss (min/max) #}

    {# Datenqualität (Beschreibung) #}

    {# Zeitliche Genauigkeit #}

    </div>
    {# Messdaten Bautechnik #}
    {% include 'partials/detail/metadata/parts/measurement/measurement_bautechnik.html.twig' ignore missing %}
