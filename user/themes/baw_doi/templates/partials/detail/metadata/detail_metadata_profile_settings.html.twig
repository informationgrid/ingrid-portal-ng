{# Zeitbezug #}
{% set timeRefs = addKeyValue(timeRefs, "timeMeasureValue", hit.timeMeasureValue) %}
{% set timeRefs = addKeyValue(timeRefs, "timeMeasureUnit", hit.timeMeasureUnit) %}

{# Raumbezug #}
{% set mapRefs = addKeyValue(mapRefs, "bwastrs", hit.bwastrs) %}

{# Bibliografische Angaben #}
{% set bibliographies = hit.bibliographies %}
{% set doi = hit.doi %}
{% set citations = hit.citations %}

{# Fachinformationen #}
{% switch class %}
    {% case '1' %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMethod", hit.measurementMethod) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementSpatialOrientation", hit.measurementSpatialOrientation) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMinDischarge", hit.measurementMinDischarge) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMaxDischarge", hit.measurementMaxDischarge) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMeasurementFrequency", hit.measurementMeasurementFrequency) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementDataQualityDescription", hit.measurementDataQualityDescription) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMeasurementDepth", hit.measurementMeasurementDepth) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMeanWaterLevel", hit.measurementMeanWaterLevel) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementGaugeDatum", hit.measurementGaugeDatum) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMeasurementDevice", hit.measurementMeasurementDevice) %}
        {% set infoRefs = addKeyValue(infoRefs, "measurementMeasuredQuantities", hit.measurementMeasuredQuantities) %}
    {% case '6' %}
        {% set infoRefs = addKeyValue(infoRefs, "erstellungsvertragsnummer", hit.erstellungsvertragsnummer) %}
        {% set infoRefs = addKeyValue(infoRefs, "erstellungsvertragsdatum", hit.erstellungsvertragsdatum) %}

    {% default %}

{% endswitch %}

{% set hierachyLevelName = hit.hierachyLevelName %}

{% set hasTimeResource = (timeRefs.timeCreation or timeRefs.timePublication or timeRefs.timeRevision or timeRefs.timeStatus or  timeRefs.timePeriod or timeRefs.timeInterval or (timeRefs.timeMeasureValue and timeRefs.timeMeasureUnit)) %}

