{# Simulationsdaten #}

{% if hasSimulation %}
    <li class="accordion-item" data-accordion-item>
        <a href="#{{ hash_simulation }}" class="accordion-title js-anchor-target" aria-hidden="true" id="{{ hash_simulation }}-accordion-label">
            <span class="text">{{ "SEARCH_DETAIL.SIMULATION.TITLE"|t }}</span>
        </a>
        <div class="accordion-content {% if not hasSimulationBautechnik and not hasSimulationCFD %}is-hidden{% endif %}" data-tab-content role="tabpanel" aria-hidden="true" aria-labelledby="{{ hash_simulation }}-accordion-label" id="{{ hash_simulation }}-accordion">
            <div class="boxes">
                {% if hasSimulation %}
                    {% set tmpHash = hash_simulation %}
                    {% set tmpTitle = "SEARCH_DETAIL.SIMULATION.TITLE"|t %}
                    {{ hit_macros.render_sub_navigation(tmpTitle, tmpHash) }}
                {% endif %}
                {% if hasSimulationBautechnik %}
                    {% set tmpHash = hash_simulationBautechnik %}
                    {% set tmpTitle = "SEARCH_DETAIL.SIMULATION.BAUTECHNIK.TITLE"|t %}
                    {{ hit_macros.render_sub_navigation(tmpTitle, tmpHash) }}
                {% endif %}
                {% if hasSimulationCFD %}
                    {% set tmpHash = hash_simulationCFD %}
                    {% set tmpTitle = "SEARCH_DETAIL.SIMULATION.CFD.TITLE"|t %}
                    {{ hit_macros.render_sub_navigation(tmpTitle, tmpHash) }}
                {% endif %}
            </div>
        </div>
    </li>
{% endif %}