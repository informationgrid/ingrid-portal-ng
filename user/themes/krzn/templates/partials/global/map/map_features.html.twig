{% if geojsons %}
    {% for geojson in geojsons %}
        addLayerWKT({{ map }}, '{{ geojson|raw }}');
    {% endfor %}
{% elseif bwastrs and map_enable_bwastr %}
    addLayerBWaStr({{ map }}, {{ bwastrs|json_encode|raw }}, 'rest/getBwastrs', coords);
{% elseif coords %}
    addLayerBounds({{ map }}, coords, {{ usePopUp ?? false }});
{% endif %}